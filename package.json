{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "set-webhook": "dotenv -e .env.local tsx scripts/set-webhook.ts",
    "check-webhook": "node -e \"require('https').get('https://api.telegram.org/bot' + process.env.TELEGRAM_BOT_TOKEN + '/getWebhookInfo', r => { let d=''; r.on('data', c => d+=c); r.on('end', () => console.log(JSON.parse(d))); })\"",
    "delete-webhook": "dotenv -e .env.local tsx scripts/delete-webhook.ts",
    "dev:tunnel": "dotenv -e .env.local -- tsx scripts/start-dev.ts"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/three": "^0.183.1",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^1.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "openai": "^6.32.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "telegraf": "^4.16.3",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "firebase-tools": "^15.11.0",
    "localtunnel": "^2.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
